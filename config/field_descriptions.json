{
  "sub_fields": {
    "use_sub_config": {
      "description": "是否使用订阅自身配置",
      "type": "bool",
      "default": "false",
      "values": {
        "true": "使用 Sub 表配置",
        "false": "继承 User/Global 配置"
      }
    },
    "state": {
      "description": "订阅推送状态",
      "type": "int",
      "default": "1",
      "values": {
        "0": "禁用推送",
        "1": "启用推送"
      }
    },
    "notify": {
      "description": "是否通知",
      "type": "int",
      "default": "1",
      "values": {
        "0": "禁用",
        "1": "启用"
      }
    },
    "send_mode": {
      "description": "发送模式",
      "type": "int",
      "default": "0",
      "values": {
        "-1": "仅链接",
        "0": "自动",
        "2": "直接消息"
      }
    },
    "interval": {
      "description": "监控间隔",
      "type": "int",
      "default": "5",
      "unit": "分钟"
    },
    "length_limit": {
      "description": "长度限制",
      "type": "int",
      "default": "0",
      "values": {
        "0": "不限制"
      }
