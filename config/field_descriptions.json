        "0": "自动",
        "1": "强制"
      }
    },
    "display_via": {
      "description": "显示来源",
      "type": "int",
      "default": "0",
      "values": {
        "-2": "完全禁用",
        "-1": "仅链接",
        "0": "自动",
        "1": "强制"
      }
    },
    "display_title": {
      "description": "显示标题",
      "type": "int",
      "default": "0",
